<%# Confirmation page after sending a devis %>
<%- include('header') %>

<main class="confirmation-page">

    <section class="confirmation-section reveal">
        <div class="confirmation-card">
            <div class="confirmation-content">
                <% if (success) { %> 
                    <div class="success-icon">✓</div>
                    <h2>Votre CV a bien été envoyé</h2>
                    <p>
                        Notre équipe étudiera votre candidature dans les meilleurs délais.
                    </p>

                    <p>
                        Sans retour sous 2 semaines, votre candidature pourra être considérée comme non retenue.
                    </p>
                    <p class="redirect-countdown">Redirection vers l'accueil dans <strong><span id="countdown">5</span>s</strong>…</p>
                <% } else { %>
                    <div class="error-icon">✗</div>
                    <h2>L’envoi de votre CV a échoué. Veuillez réessayer dans quelques instants.</h2>
                    <p><%= message %></p>
                    <a href="/devis" class="btn-retry">Réessayer</a>
                <% } %>
            </div>
        </div>
    </section>
</main>


<script>

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, {
        threshold: 0.1
    });

    document.querySelectorAll('.reveal').forEach(el => {
        observer.observe(el);
    });

    document.querySelectorAll('.reveal-machine').forEach(el => {
        observer.observe(el);
    });





  document.addEventListener('DOMContentLoaded', function () {
    <% if (success) { %>
      var seconds = 5;
      var countdownEl = document.getElementById('countdown');

      var interval = setInterval(function () {
        seconds--;
        if (countdownEl) countdownEl.textContent = seconds;
        if (seconds <= 0) {
          clearInterval(interval);
          window.location.href="/"
        }
      }, 1000);
    <% } %>
  });
</script>