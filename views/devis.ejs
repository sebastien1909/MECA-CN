<%# Request (devis) form %> <%- include("header") %>

<!-- Modal Captcha -->
<div class="captcha-modal-overlay" id="captcha-modal" aria-hidden="true">
  <div class="captcha-modal" role="dialog" aria-modal="true" aria-labelledby="captcha-modal-title">
    <h3 id="captcha-modal-title">Vérification anti-robot</h3>
    <p>Répondez à cette question pour confirmer votre envoi.</p>
    <div class="captcha-question">
      <span id="captcha-question-text"></span> = ?
    </div>
    <input
      type="number"
      id="captcha-input"
      placeholder="Votre réponse"
      autocomplete="off"
    />
    <p class="captcha-error" id="captcha-error" aria-live="polite"></p>
    <div class="captcha-modal-actions">
      <button type="button" id="cancel-captcha">Annuler</button>
      <button type="button" id="confirm-captcha" class="btn-captcha-confirm">
        Envoyer ma demande
      </button>
    </div>
  </div>
</div>


<main class="devis-page">
  <section class="devis-hero pc-only">
    <div class="devis-hero-copy">
      <p class="devis-hero-label">RÉPONSE EN MOINS DE 24H</p>
      <h1>Vous voulez un devis ? <span>Nous nous en occupons.</span></h1>
      <p class="devis-hero-text">
        Vous avez un projet d"usinage complexe ou une pièce spécifique à
        réaliser ? Transmettez-nous vos plans. Nos experts analysent vos besoins
        techniques avec précision.
      </p>
    </div>
  </section>

  <div class="stepper-container mobile-only">
    <div class="progress-bar">
      <div class="progress-fill" id="progress-fill" style="width: 16.66%"></div>
    </div>
    <p class="step-label">Étape <span id="current-step-num">1</span>/6</p>
  </div>

  <section class="devis-form-section">
    <div class="devis-form-card">
      <form
        class="devis-form"
        id="multistep-form"
        action="/envoyer-devis"
        method="post"
        enctype="multipart/form-data"
      >
        <section class="form-step active" id="step-1">
          <h2>Renseignez vos <span>informations</span></h2>
          <div class="form-row">
            <div class="form-group">
              <label>Nom complet *</label>
              <input type="text" name="nom" placeholder="Votre nom" required />
            </div>
            <div class="form-group">
              <label>Nom de l'entreprise</label>
              <input type="text" name="entreprise" placeholder="Société" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Adresse email *</label>
              <input
                type="email"
                name="email"
                placeholder="votre@email.com"
                required
              />
            </div>
            <div class="form-group">
              <label>Téléphone</label>
              <input type="tel" name="telephone" placeholder="06 .. .. .. .." />
            </div>
          </div>
          <div class="nav-btns mobile-only">
            <button type="button" class="btn-next" onclick="nextStep(2)">
              Suivant →
            </button>
          </div>
        </section>

        <section class="form-step" id="step-2">
          <button
            type="button"
            class="btn-back mobile-only"
            onclick="nextStep(1)"
          >
            ← Retourner en arrière
          </button>
          <h2>Détails du <span>produit</span></h2>
          <div class="form-row">
            <div class="form-group">
              <label>Nom du produit *</label>
              <input
                type="text"
                name="produit"
                placeholder="Ex: Engrenage"
                required
              />
            </div>
            <div class="form-group">
              <label>Matière souhaitée</label>
              <input
                type="text"
                name="matiere"
                placeholder="Ex: Acier, Alu..."
              />
              <input type="hidden" name="matiere_fourniture" id="matiere-fourniture-hidden" value="" />
            </div>
             <!-- Modale fourniture matière -->
              <div class="matiere-modal-overlay" id="matiere-modal" aria-hidden="true">
                <div class="matiere-modal" role="dialog" aria-modal="true" aria-labelledby="matiere-modal-title">
                  <h3 id="matiere-modal-title">Fourniture de la matière</h3>
                  <p>Concernant la matière <strong id="matiere-modal-nom"></strong>, qui la fournit ?</p>
                  <div class="matiere-modal-actions">
                    <button type="button" id="matiere-client">✔ Je la fournis moi-même</button>
                    <button type="button" id="matiere-entreprise" class="btn-matiere-highlight">✔ MECA-CN la fournit</button>
                  </div>
                </div>
              </div>




          </div>
          <div class="nav-btns mobile-only">
            <button type="button" class="btn-next" onclick="nextStep(3)">
              Suivant →
            </button>
          </div>
        </section>

        <section class="form-step" id="step-3">
          <button
            type="button"
            class="btn-back mobile-only"
            onclick="nextStep(2)"
          >
            ← Retourner en arrière
          </button>
          <h2>Quantité et <span>délais</span></h2>

          <div class="form-group" style="margin-bottom: 24px">
            <label>Quantité demandée *</label>
            <input
              type="number"
              name="quantite"
              min="1"
              placeholder="Nombre de pièces"
              required
            />
          </div>

          <div class="form-row" style="margin-bottom: 24px">
            <div class="form-group">
              <label>Dimension X *</label>
              <div class="input-unit-group">
                <input
                  type="number"
                  name="display_dim_x"
                  min="0.01"
                  step="0.01"
                  placeholder="Long."
                  required
                />
                <select class="unit-selector" id="unit_x">
                  <option value="mm">mm</option>
                  <option value="cm">cm</option>
                  <option value="dm">dm</option>
                </select>
              </div>
              <input type="hidden" name="dim_x" />
            </div>

            <div class="form-group">
              <label>Dimension Y *</label>
              <div class="input-unit-group">
                <input
                  type="number"
                  name="display_dim_y"
                  min="0.01"
                  step="0.01"
                  placeholder="Larg."
                  required
                />
                <select class="unit-selector" id="unit_y">
                  <option value="mm">mm</option>
                  <option value="cm">cm</option>
                  <option value="dm">dm</option>
                </select>
              </div>
              <input type="hidden" name="dim_y" />
            </div>

            <div class="form-group">
              <label>Dimension Z *</label>
              <div class="input-unit-group">
                <input
                  type="number"
                  name="display_dim_z"
                  min="0.01"
                  step="0.01"
                  placeholder="Haut."
                  required
                />
                <select class="unit-selector" id="unit_z">
                  <option value="mm">mm</option>
                  <option value="cm">cm</option>
                  <option value="dm">dm</option>
                </select>
              </div>
              <input type="hidden" name="dim_z" />
            </div>
          </div>

          <label>Choisissez une date de livraison souhaitée *</label>
          <div class="elegant-calencar">
            <input
              type="hidden"
              name="date_livraison"
              id="date_livraison_input"
              required
            />

            <div id="calendar-header-box" class="clearfix">
              <div class="pre-button">←</div>
              <div class="head-info">
                <div class="head-day"></div>
                <div class="head-month"></div>
              </div>
              <div class="next-button">→</div>
            </div>
            <table id="calendar">
              <thead>
                <tr>
                  <th>Lun</th>
                  <th>Mar</th>
                  <th>Mer</th>
                  <th>Jeu</th>
                  <th>Ven</th>
                  <th>Sam</th>
                  <th>Dim</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                </tr>
                <tr>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                </tr>
                <tr>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                </tr>
                <tr>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                </tr>
                <tr>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                </tr>
                <tr>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="nav-btns mobile-only">
            <button type="button" class="btn-next" onclick="nextStep(4)">
              Suivant →
            </button>
          </div>
        </section>

        <section class="form-step" id="step-4">
          <button
            type="button"
            class="btn-back mobile-only"
            onclick="nextStep(3)"
          >
            ← Retourner en arrière
          </button>
          <h2>Plans et <span>fichiers</span></h2>
          <div class="upload-box">
            <div class="upload-icon">⇪</div>
            <p>Glissez-déposez vos plans</p>
            <span>Fichiers 3D, PDF, images...</span>
            <button type="button" class="upload-button">
              Chercher un/des fichiers
            </button>
            <input type="file" name="fichiers" multiple id="fichiers-input" />
          </div>
          <p class="upload-restrictions">
            Les fichiers compressés (ZIP) ne sont pas acceptés. <br />Taille
            maximale par fichier : 20 Mo. <br />Taille totale maximale : 250 Mo.
          </p>
          <br />
          <div class="upload-files-preview" id="upload-files-preview">
            <p class="upload-files-empty">Aucun fichier sélectionné.</p>
          </div>
          <div class="nav-btns mobile-only">
            <button type="button" class="btn-next" onclick="nextStep(5)">
              Suivant →
            </button>
          </div>
        </section>

        <div
          class="confirm-modal-overlay"
          id="confirm-modal"
          aria-hidden="true"
        >
          <div
            class="confirm-modal"
            role="dialog"
            aria-modal="true"
            aria-labelledby="confirm-modal-title"
          >
            <h3 id="confirm-modal-title">Confirmer la suppression</h3>
            <p>Êtes-vous sûr de vouloir supprimer ce fichier ?</p>
            <div class="confirm-modal-actions">
              <button type="button" class="btn-modal-cancel" id="cancel-remove">
                Annuler
              </button>
              <button
                type="button"
                class="btn-modal-confirm"
                id="confirm-remove"
              >
                Supprimer
              </button>
            </div>
          </div>
        </div>

        <div class="error-modal-overlay" id="error-modal" aria-hidden="true">
          <div
            class="error-modal"
            role="dialog"
            aria-modal="true"
            aria-labelledby="error-modal-title"
          >
            <h3 id="error-modal-title">Dimensions incompatibles</h3>
            <p id="error-modal-message">
              Les dimensions de votre pièce dépassent les capacités de nos
              machines.
            </p>
            <div class="error-modal-actions">
              <button type="button" class="btn-modal-ok" id="close-error-modal">
                Compris
              </button>
            </div>
          </div>
        </div>

        <section class="form-step" id="step-5">
          <button
            type="button"
            class="btn-back mobile-only"
            onclick="nextStep(4)"
          >
            ← Retourner en arrière
          </button>
          <h2>Description <span>complémentaire</span></h2>
          <div class="form-group full">
            <label>Avez-vous d'autres informations ?</label>
            <textarea
              name="description"
              rows="6"
              placeholder="Précisions techniques, finitions..."
              maxlength="8192"
            ></textarea>
          </div>
          <div class="nav-btns mobile-only">
            <button type="button" class="btn-next" onclick="nextStep(6)">
              Voir le récapitulatif →
            </button>
          </div>
        </section>

        <section class="form-step" id="step-6">
          <button
            type="button"
            class="btn-back mobile-only"
            onclick="nextStep(5)"
          >
            ← Modifier mes informations
          </button>
          <h2 class="pc-hidden">Validez vos <span>données</span></h2>

          <div id="recap-display" class="recap-box pc-hidden"></div>

          <button type="submit" class="devis-submit">
            Envoyer la demande définitive
          </button>
        </section>
      </form>
    </div>
  </section>




  <div class="sending-overlay" id="sending-overlay" aria-hidden="true">
    <div class="sending-card">
      <div class="sending-spinner"></div>
      <p class="sending-title">Envoi en cours...</p>
      <p class="sending-subtitle">Merci de patienter, votre demande est en cours d'envoi.</p>
    </div>
  </div>




</main>

<script>
  document.addEventListener("DOMContentLoaded", function () {

    // ── VARIABLES GLOBALES ───────────────────────────────────────────
    var maxDimensions = null;
    var captchaQuestion = "<%= captchaQuestion %>";

    // Charger les dimensions max des machines
    fetch("/api/max-dimensions")
      .then((response) => response.json())
      .then((data) => {
        maxDimensions = data;
        console.log("Max dimensions:", maxDimensions);
      })
      .catch((err) => console.error("Erreur chargement dimensions:", err));


    // ── CONVERSION D'UNITÉS ──────────────────────────────────────────
    function convertToMm(value, unit) {
      const val = parseFloat(value) || 0;
      switch (unit) {
        case "cm": return val * 10;
        case "dm": return val * 100;
        default:   return val;
      }
    }

    function updateHiddenDimensions() {
      ["x", "y", "z"].forEach((d) => {
        const displayVal = document.querySelector(`input[name="display_dim_${d}"]`).value;
        const unit = document.getElementById(`unit_${d}`).value;
        document.querySelector(`input[name="dim_${d}"]`).value = convertToMm(displayVal, unit);
      });
    }


    // ── VALIDATION DES DIMENSIONS ────────────────────────────────────
    function validateDimensions() {
      if (!maxDimensions) {
        showErrorModal("Erreur technique", "Impossible de vérifier les dimensions.");
        return false;
      }

      updateHiddenDimensions();

      const dimX = parseFloat(document.querySelector("input[name='dim_x']").value) || 0;
      const dimY = parseFloat(document.querySelector("input[name='dim_y']").value) || 0;
      const dimZ = parseFloat(document.querySelector("input[name='dim_z']").value) || 0;

      if (dimX > maxDimensions.max_x || dimY > maxDimensions.max_y || dimZ > maxDimensions.max_z) {
        showErrorModal(
          "Dimensions incompatibles",
          `Les dimensions (${dimX}x${dimY}x${dimZ} mm) dépassent les capacités (max: ${maxDimensions.max_x}x${maxDimensions.max_y}x${maxDimensions.max_z} mm).`
        );
        return false;
      }
      return true;
    }


    // ── MODAL ERREUR DIMENSIONS ──────────────────────────────────────
    var errorModal = document.getElementById("error-modal");
    var closeErrorModalButton = document.getElementById("close-error-modal");

    function showErrorModal(title, message) {
      document.getElementById("error-modal-title").textContent = title;
      document.getElementById("error-modal-message").textContent = message;
      errorModal.classList.add("visible");
      errorModal.setAttribute("aria-hidden", "false");
    }

    function hideErrorModal() {
      errorModal.classList.remove("visible");
      errorModal.setAttribute("aria-hidden", "true");
    }

    closeErrorModalButton.addEventListener("click", hideErrorModal);
    errorModal.addEventListener("click", function (e) {
      if (e.target === errorModal) hideErrorModal();
    });


    // ── CALENDRIER ───────────────────────────────────────────────────
    var today = new Date(),
      year = today.getFullYear(),
      month = today.getMonth(),
      monthTag = ["Jan","Fév","Mar","Avr","Mai","Juin","Juil","Août","Sep","Oct","Nov","Déc"],
      day = today.getDate(),
      days = document.getElementById("calendar").getElementsByTagName("td"),
      selectedDay,
      setDate,
      daysLen = days.length;

    function Calendar(selector, options) {
      this.options = options;
      this.draw();
    }

    Calendar.prototype.draw = function () {
      this.getOptions();
      this.drawDays();
      var that = this;
      document.getElementsByClassName("pre-button")[0].addEventListener("click", function () { that.preMonth(); });
      document.getElementsByClassName("next-button")[0].addEventListener("click", function () { that.nextMonth(); });
      for (var k = 0; k < daysLen; k++) {
        days[k].addEventListener("click", function () { that.clickDay(this); });
      }
    };

    Calendar.prototype.drawHeader = function (e) {
      var headDay = document.getElementsByClassName("head-day");
      var headMonth = document.getElementsByClassName("head-month");
      e ? (headDay[0].innerHTML = e) : (headDay[0].innerHTML = day);
      headMonth[0].innerHTML = monthTag[month] + " - " + year;
    };

    Calendar.prototype.drawDays = function () {
      var startDay = (new Date(year, month, 1).getDay() + 6) % 7;
      var nDays = new Date(year, month + 1, 0).getDate();
      var n = startDay;

      for (var k = 0; k < 42; k++) {
        days[k].innerHTML = "";
        days[k].id = "";
        days[k].className = "";
      }
      for (var i = 1; i <= nDays; i++) {
        days[n].innerHTML = i;
        n++;
      }
      for (var j = 0; j < 42; j++) {
        if (days[j].innerHTML === "") {
          days[j].id = "disabled";
        } else if (j === day + startDay - 1 && month === today.getMonth() && year === today.getFullYear()) {
          this.drawHeader(day);
          days[j].id = "today";
        }
        if (selectedDay) {
          if (j === selectedDay.getDate() + startDay - 1 && month === selectedDay.getMonth() && year === selectedDay.getFullYear()) {
            days[j].className = "selected";
            this.drawHeader(selectedDay.getDate());
          }
        }
        if (days[j].innerHTML !== "") {
          var date = new Date(year, month, parseInt(days[j].innerHTML));
          var dow = date.getDay();
          if (dow === 0 || dow === 6) {
            days[j].classList.add("weekend");
          }
        }
      }
    };

    Calendar.prototype.clickDay = function (o) {
      if (o.innerHTML === "") return;

      var clickedDate = new Date(year, month, o.innerHTML); // ← déclaré EN PREMIER
      var todayMidnight = new Date();
      todayMidnight.setHours(0, 0, 0, 0);

      var dayOfWeek = clickedDate.getDay(); // ← maintenant clickedDate existe
      if (dayOfWeek === 0 || dayOfWeek === 6) {
        showErrorModal("Jour non ouvrable", "Veuillez choisir un jour de semaine (lundi au vendredi).");
        return;
      }

      if (clickedDate < todayMidnight) {
        showErrorModal("Date invalide", "La date sélectionnée ne peut pas être antérieure à aujourd'hui. Veuillez choisir une date future.");
        return;
      }

      var selected = document.getElementsByClassName("selected");
      if (selected.length !== 0) selected[0].className = "";
      o.className = "selected";
      selectedDay = clickedDate;
      this.drawHeader(o.innerHTML);
      document.getElementById("date_livraison_input").value = selectedDay.toLocaleDateString("fr-FR");
    };

    Calendar.prototype.preMonth = function () {
      if (month < 1) { month = 11; year--; } else { month--; }
      this.drawHeader(1);
      this.drawDays();
    };

    Calendar.prototype.nextMonth = function () {
      if (month >= 11) { month = 0; year++; } else { month++; }
      this.drawHeader(1);
      this.drawDays();
    };

    Calendar.prototype.getOptions = function () {
      if (this.options) {
        var sets = this.options.split("-");
        setDate = new Date(sets[0], sets[1] - 1, sets[2]);
        day = setDate.getDate();
        year = setDate.getFullYear();
        month = setDate.getMonth();
      }
    };

    var calendar = new Calendar();


    // ── UPLOAD FICHIERS ──────────────────────────────────────────────
    var fileInput = document.getElementById("fichiers-input");
    var uploadBox = document.querySelector(".upload-box");
    var filePreview = document.getElementById("upload-files-preview");
    var uploadButton = document.querySelector(".upload-button");
    var selectedFiles = [];
    var MAX_FILE_SIZE = 20 * 1024 * 1024;
    var MAX_TOTAL_SIZE = 250 * 1024 * 1024;

    function formatBytes(bytes) {
      if (bytes === 0) return "0 octet";
      var sizes = ["octets", "Ko", "Mo", "Go"];
      var i = Math.floor(Math.log(bytes) / Math.log(1024));
      return Math.round(bytes / Math.pow(1024, i)) + " " + sizes[i];
    }

    function validateFiles(files, existingFiles) {
      var filtered = [], errors = [];
      var totalSize = existingFiles.reduce(function (sum, f) { return sum + f.size; }, 0);

      files.forEach(function (file) {
        var ext = file.name.split(".").pop().toLowerCase();
        if (ext === "zip") { errors.push("Les fichiers ZIP ne sont pas autorisés : " + file.name); return; }
        if (file.size > MAX_FILE_SIZE) { errors.push("Fichier trop volumineux (> 20 Mo) : " + file.name); return; }
        if (totalSize + file.size > MAX_TOTAL_SIZE) { errors.push("La taille totale dépasse 250 Mo avec : " + file.name); return; }
        totalSize += file.size;
        filtered.push(file);
      });

      return { files: filtered, errors: errors };
    }

    function displayUploadError(message) {
      var errorHtml = "<div class='upload-files-error'>" + message + "</div>";
      var errorNode = filePreview.querySelector(".upload-files-error");
      if (errorNode) { errorNode.outerHTML = errorHtml; } else { filePreview.insertAdjacentHTML("beforeend", errorHtml); }
    }

    function clearUploadError() {
      var errorNode = filePreview.querySelector(".upload-files-error");
      if (errorNode) errorNode.remove();
    }

    function updateFileInput() {
      var dataTransfer = new DataTransfer();
      selectedFiles.forEach(function (file) { dataTransfer.items.add(file); });
      fileInput.files = dataTransfer.files;
    }

    function updateFilePreview() {
      clearUploadError();
      if (selectedFiles.length === 0) {
        filePreview.innerHTML = '<p class="upload-files-empty">Aucun fichier sélectionné.</p>';
        return;
      }
      var totalSize = selectedFiles.reduce(function (sum, f) { return sum + f.size; }, 0);
      filePreview.innerHTML =
        "<p>Fichiers sélectionnés</p><ul>" +
        selectedFiles.map(function (file, index) {
          return '<li><span class="file-name">' + file.name + '</span><span class="file-size">' + formatBytes(file.size) +
            '</span><button type="button" class="file-remove" data-index="' + index + '">Supprimer</button></li>';
        }).join("") +
        "</ul><div class='upload-files-total'>Total : " + formatBytes(totalSize) + " / 250 Mo</div>";
    }




    // ── MODALE FOURNITURE MATIÈRE ────────────────────────────────────
    var matiereInput = document.querySelector('input[name="matiere"]');
    var matiereModal = document.getElementById("matiere-modal");
    var matiereFournitureHidden = document.getElementById("matiere-fourniture-hidden");

    matiereInput.addEventListener("blur", function () {
      var val = matiereInput.value.trim();
      if (!val) return;
      document.getElementById("matiere-modal-nom").textContent = val;
      matiereModal.classList.add("visible");
      matiereModal.setAttribute("aria-hidden", "false");
    });

    document.getElementById("matiere-client").addEventListener("click", function () {
      matiereFournitureHidden.value = "client";
      matiereModal.classList.remove("visible");
      matiereModal.setAttribute("aria-hidden", "true");
    });

    document.getElementById("matiere-entreprise").addEventListener("click", function () {
      matiereFournitureHidden.value = "entreprise";
      matiereModal.classList.remove("visible");
      matiereModal.setAttribute("aria-hidden", "true");
    });




    var pendingRemoveIndex = null;
    var confirmModal = document.getElementById("confirm-modal");
    var confirmRemoveButton = document.getElementById("confirm-remove");
    var cancelRemoveButton = document.getElementById("cancel-remove");

    function showConfirmModal(index) {
      pendingRemoveIndex = index;
      confirmModal.classList.add("visible");
      confirmModal.setAttribute("aria-hidden", "false");
    }

    function hideConfirmModal() {
      pendingRemoveIndex = null;
      confirmModal.classList.remove("visible");
      confirmModal.setAttribute("aria-hidden", "true");
    }

    uploadButton.addEventListener("click", function () { fileInput.click(); });

    fileInput.addEventListener("change", function () {
      var validation = validateFiles(Array.from(fileInput.files || []), selectedFiles);
      selectedFiles = selectedFiles.concat(validation.files);
      updateFileInput();
      updateFilePreview();
      if (validation.errors.length) displayUploadError(validation.errors.join("<br>"));
    });

    filePreview.addEventListener("click", function (e) {
      var button = e.target.closest(".file-remove");
      if (!button) return;
      showConfirmModal(Number(button.dataset.index));
    });

    confirmRemoveButton.addEventListener("click", function () {
      if (pendingRemoveIndex !== null) {
        selectedFiles.splice(pendingRemoveIndex, 1);
        updateFileInput();
        updateFilePreview();
      }
      hideConfirmModal();
    });

    cancelRemoveButton.addEventListener("click", hideConfirmModal);
    confirmModal.addEventListener("click", function (e) { if (e.target === confirmModal) hideConfirmModal(); });

    uploadBox.addEventListener("dragover", function (e) { e.preventDefault(); uploadBox.classList.add("drag-over"); });
    uploadBox.addEventListener("dragleave", function () { uploadBox.classList.remove("drag-over"); });
    uploadBox.addEventListener("drop", function (e) {
      e.preventDefault();
      uploadBox.classList.remove("drag-over");
      var validation = validateFiles(Array.from(e.dataTransfer.files || []), selectedFiles);
      selectedFiles = selectedFiles.concat(validation.files);
      updateFileInput();
      updateFilePreview();
      if (validation.errors.length) displayUploadError(validation.errors.join("<br>"));
    });

    updateFilePreview();


    // ── STEPPER (NAVIGATION MOBILE) ──────────────────────────────────
    window.nextStep = function (step) {
      if (window.innerWidth <= 768) {
        if (step === 4 && !validateDimensions()) return;

        document.querySelectorAll(".form-step").forEach((s) => s.classList.remove("active"));
        document.getElementById("step-" + step).classList.add("active");

        var progressFill = document.getElementById("progress-fill");
        var stepNumDisplay = document.getElementById("current-step-num");
        if (progressFill) progressFill.style.width = (step / 6 * 100) + "%";
        if (stepNumDisplay) stepNumDisplay.innerText = step;

        window.scrollTo(0, 0);
      }
      if (step === 6) generateRecap();
    };


    // ── RÉCAPITULATIF ────────────────────────────────────────────────
    function generateRecap() {
      var recapBox = document.getElementById("recap-display");
      updateHiddenDimensions();

      var data = {
        nom:         document.querySelector('input[name="nom"]').value         || "Non précisé",
        entreprise:  document.querySelector('input[name="entreprise"]').value  || "Non précisé",
        email:       document.querySelector('input[name="email"]').value       || "Non précisé",
        produit:     document.querySelector('input[name="produit"]').value     || "Non précisé",
        quantite:    document.querySelector('input[name="quantite"]').value    || "0",
        dim_x:       document.querySelector('input[name="dim_x"]').value      || "0",
        dim_y:       document.querySelector('input[name="dim_y"]').value      || "0",
        dim_z:       document.querySelector('input[name="dim_z"]').value      || "0",
        date:        document.getElementById("date_livraison_input").value    || "Non sélectionnée",
        description: document.querySelector('textarea[name="description"]').value || "Aucune description",
      };

      var fichiersHtml = selectedFiles.length > 0
        ? "<p><strong>Fichiers joints :</strong></p><ul>" + selectedFiles.map(function (f) { return "<li>" + f.name + " (" + formatBytes(f.size) + ")</li>"; }).join("") + "</ul>"
        : "<p><strong>Fichiers joints :</strong> Aucun fichier</p>";

      recapBox.innerHTML = `
        <div class="recap-content">
          <p><strong>Nom complet :</strong> ${data.nom}</p>
          <p><strong>Entreprise :</strong> ${data.entreprise}</p>
          <p><strong>Contact :</strong> ${data.email}</p>
          <p><strong>Produit :</strong> ${data.produit} (${data.quantite} pièces)</p>
          <p><strong>Dimensions :</strong> ${data.dim_x} x ${data.dim_y} x ${data.dim_z} mm</p>
          <p><strong>Délais souhaités :</strong> ${data.date}</p>
          <p><strong>Description :</strong> ${data.description.substring(0, 100)}${data.description.length > 100 ? "..." : ""}</p>
          ${fichiersHtml}
        </div>`;
    }


    // ── CAPTCHA MAISON ───────────────────────────────────────────────
    var captchaModal = document.getElementById("captcha-modal");
    var captchaInput = document.getElementById("captcha-input");
    var captchaError = document.getElementById("captcha-error");
    var confirmCaptchaBtn = document.getElementById("confirm-captcha");
    var cancelCaptchaBtn = document.getElementById("cancel-captcha");
    var devisForm = document.getElementById("multistep-form");

    document.getElementById("captcha-question-text").textContent = captchaQuestion;

    function openCaptchaModal() {
      captchaInput.value = "";
      captchaError.textContent = "";
      captchaModal.classList.add("visible");
      captchaModal.setAttribute("aria-hidden", "false");
      captchaInput.focus();
    }

    function closeCaptchaModal() {
      captchaModal.classList.remove("visible");
      captchaModal.setAttribute("aria-hidden", "true");
    }

    // Intercepte le submit → ouvre la modal captcha
    devisForm.addEventListener("submit", function (e) {
      e.preventDefault();
      updateHiddenDimensions();
      if (!validateDimensions()) return;
      openCaptchaModal();
    });

    // Bouton "Envoyer" dans la modal captcha
    confirmCaptchaBtn.addEventListener("click", function () {
      if (captchaInput.value.trim() === "") {
        captchaError.textContent = "Veuillez entrer une réponse.";
        captchaInput.focus();
        return;
      }

      var hiddenInput = document.getElementById("captcha-answer-hidden");
      if (!hiddenInput) {
        hiddenInput = document.createElement("input");
        hiddenInput.type = "hidden";
        hiddenInput.name = "captcha_answer";
        hiddenInput.id = "captcha-answer-hidden";
        devisForm.appendChild(hiddenInput);
      }
      hiddenInput.value = captchaInput.value.trim();

      closeCaptchaModal();

      var overlay = document.getElementById("sending-overlay");
      overlay.classList.add("visible");
      overlay.setAttribute("aria-hidden", "false");

      devisForm.submit();
    });

    // Valider avec la touche Entrée
    captchaInput.addEventListener("keydown", function (e) {
      if (e.key === "Enter") confirmCaptchaBtn.click();
    });

    cancelCaptchaBtn.addEventListener("click", closeCaptchaModal);
    captchaModal.addEventListener("click", function (e) {
      if (e.target === captchaModal) closeCaptchaModal();
    });
    // ────────────────────────────────────────────────────────────────

  }, false);
</script>

<%- include("footer") %>
