<%- include ("header") %>
<br>
<a href="/offre/<%= offre.offre_id %>" class="retour-arriere">Retourner en arrière</a>

<!-- Modal confirmation suppression fichier -->
<div class="confirm-modal-overlay" id="confirm-modal" aria-hidden="true">
  <div class="confirm-modal" role="dialog" aria-modal="true" aria-labelledby="confirm-modal-title">
    <h3 id="confirm-modal-title">Confirmer la suppression</h3>
    <p>Êtes-vous sûr de vouloir supprimer ce fichier ?</p>
    <div class="confirm-modal-actions">
      <button type="button" class="btn-modal-cancel" id="cancel-remove">Annuler</button>
      <button type="button" class="btn-modal-confirm" id="confirm-remove">Supprimer</button>
    </div>
  </div>
</div>

<div class="form-holder">
  <form method="POST" action="/envoyer_cv" enctype="multipart/form-data">

    <!-- Champ caché pour tracer l'offre concernée -->
    <input type="hidden" name="offre_id" value="<%= offre.offre_id %>" />
    <input type="hidden" name="type" value="<%=offre.type%>" />

    <div class="mail-holder">
      <label for="mail">Adresse email</label>
      <input type="email" id="mail" name="mail" placeholder="Veuillez renseigner votre adresse email" required />
    </div>

    <div class="name-holder">
      <label for="name">Nom complet</label>
      <input type="text" id="name" name="name" placeholder="Jean Dupont" required />
    </div>

    <div class="message-holder">
      <label for="message">Entrez votre message</label>
      <textarea id="message" name="message" placeholder="Lettre de motivation ou autre" class="message-input"></textarea>
    </div>

    <div class="cv-import">
      <h2>Envoyez-nous votre <span>CV</span></h2>
      <div class="upload-box">
        <div class="upload-icon">⇪</div>
        <p>Glissez-déposez vos fichiers</p>
        <span>CV, lettre de motivation, PDF...</span>
        <button type="button" class="upload-button">
          Chercher un/des fichiers
        </button>
        <input type="file" name="fichiers" multiple id="fichiers-input" />
      </div>
      <p class="upload-restrictions">
        Certains types de fichiers potentiellement dangereux (.zip, .bat, .exe, .js...)
        <br />ne sont pas acceptés.
        <br /><br />
        Taille maximale par fichier : 10 Mo.<br />
        Taille totale maximale : 20 Mo.<br />
      </p>
      <br />
      <div class="upload-files-preview" id="upload-files-preview">
        <p class="upload-files-empty">Aucun fichier sélectionné.</p>
      </div>
    </div>

    <button type="submit" class="submit-btn">Envoyer</button>
  </form>
</div>

<%- include("footer") %>

<script>
  document.addEventListener("DOMContentLoaded", function () {

    var EXTENSIONS_INTERDITES = ["zip", "rar", "exe", "bat", "cmd", "js", "vbs", "doc", "xls", "ppt"];
    var MAX_FILE_SIZE  = 10 * 1024 * 1024;   // 10 Mo
    var MAX_TOTAL_SIZE = 20 * 1024 * 1024;   // 20 Mo

    var fileInput    = document.getElementById("fichiers-input");
    var uploadBox    = document.querySelector(".upload-box");
    var filePreview  = document.getElementById("upload-files-preview");
    var uploadButton = document.querySelector(".upload-button");

    var selectedFiles     = [];
    var pendingRemoveIndex = null;
    var confirmModal       = document.getElementById("confirm-modal");
    var confirmRemoveBtn   = document.getElementById("confirm-remove");
    var cancelRemoveBtn    = document.getElementById("cancel-remove");

    // ── Formatage de la taille ───────────────────────────────────────
    function formatBytes(bytes) {
      if (bytes === 0) return "0 octet";
      var sizes = ["octets", "Ko", "Mo", "Go"];
      var i = Math.floor(Math.log(bytes) / Math.log(1024));
      return Math.round(bytes / Math.pow(1024, i)) + " " + sizes[i];
    }

    // ── Validation des fichiers ──────────────────────────────────────
    function validateFiles(files, existingFiles) {
      var filtered = [];
      var errors   = [];
      var totalSize = existingFiles.reduce(function (sum, f) { return sum + f.size; }, 0);

      files.forEach(function (file) {
        var ext = file.name.split(".").pop().toLowerCase();

        if (EXTENSIONS_INTERDITES.includes(ext)) {
          errors.push("Fichier non autorisé (." + ext + ") : " + file.name);
          return;
        }
        if (file.size > MAX_FILE_SIZE) {
          errors.push("Fichier trop volumineux (> 10 Mo) : " + file.name);
          return;
        }
        if (totalSize + file.size > MAX_TOTAL_SIZE) {
          errors.push("La taille totale dépasserait 20 Mo avec : " + file.name);
          return;
        }

        totalSize += file.size;
        filtered.push(file);
      });

      return { files: filtered, errors: errors };
    }

    // ── Mise à jour de l'input file natif ───────────────────────────
    function updateFileInput() {
      var dt = new DataTransfer();
      selectedFiles.forEach(function (f) { dt.items.add(f); });
      fileInput.files = dt.files;
    }

    // ── Affichage des erreurs ────────────────────────────────────────
    function displayUploadError(message) {
      var existing = filePreview.querySelector(".upload-files-error");
      var html = "<div class='upload-files-error'>" + message + "</div>";
      if (existing) { existing.outerHTML = html; }
      else          { filePreview.insertAdjacentHTML("beforeend", html); }
    }

    function clearUploadError() {
      var node = filePreview.querySelector(".upload-files-error");
      if (node) node.remove();
    }

    // ── Rendu de la liste de fichiers ────────────────────────────────
    function updateFilePreview() {
      clearUploadError();

      if (selectedFiles.length === 0) {
        filePreview.innerHTML = '<p class="upload-files-empty">Aucun fichier sélectionné.</p>';
        return;
      }

      var totalSize  = selectedFiles.reduce(function (sum, f) { return sum + f.size; }, 0);
      var pct        = Math.min(100, Math.round((totalSize / MAX_TOTAL_SIZE) * 100));
      var barColor   = pct >= 90 ? "#ef4444" : pct >= 70 ? "#f59e0b" : "#0f4bb7";

      var listItems = selectedFiles.map(function (file, index) {
        return (
          '<li>' +
            '<span class="file-name">' + file.name + '</span>' +
            '<span class="file-size">' + formatBytes(file.size) + '</span>' +
            '<button type="button" class="file-remove" data-index="' + index + '">Supprimer</button>' +
          '</li>'
        );
      }).join("");

      filePreview.innerHTML =
        '<p>Fichiers sélectionnés</p>' +
        '<ul>' + listItems + '</ul>' +
        '<div class="upload-files-total">' +
          '<div class="upload-size-bar-track">' +
            '<div class="upload-size-bar-fill" style="width:' + pct + '%; background:' + barColor + ';"></div>' +
          '</div>' +
          '<span>' + formatBytes(totalSize) + ' / ' + formatBytes(MAX_TOTAL_SIZE) + '</span>' +
        '</div>';
    }

    // ── Modals ───────────────────────────────────────────────────────
    function showConfirmModal(index) {
      pendingRemoveIndex = index;
      confirmModal.classList.add("visible");
      confirmModal.setAttribute("aria-hidden", "false");
    }

    function hideConfirmModal() {
      pendingRemoveIndex = null;
      confirmModal.classList.remove("visible");
      confirmModal.setAttribute("aria-hidden", "true");
    }

    confirmRemoveBtn.addEventListener("click", function () {
      if (pendingRemoveIndex !== null) {
        selectedFiles.splice(pendingRemoveIndex, 1);
        updateFileInput();
        updateFilePreview();
      }
      hideConfirmModal();
    });

    cancelRemoveBtn.addEventListener("click", hideConfirmModal);
    confirmModal.addEventListener("click", function (e) {
      if (e.target === confirmModal) hideConfirmModal();
    });

    // ── Bouton "Chercher" ────────────────────────────────────────────
    uploadButton.addEventListener("click", function () { fileInput.click(); });

    // ── Sélection via l'explorateur ──────────────────────────────────
    fileInput.addEventListener("change", function () {
      var validation = validateFiles(Array.from(fileInput.files || []), selectedFiles);
      selectedFiles  = selectedFiles.concat(validation.files);
      updateFileInput();
      updateFilePreview();
      if (validation.errors.length) displayUploadError(validation.errors.join("<br>"));
    });

    // ── Clic "Supprimer" dans la liste ───────────────────────────────
    filePreview.addEventListener("click", function (e) {
      var btn = e.target.closest(".file-remove");
      if (!btn) return;
      showConfirmModal(Number(btn.dataset.index));
    });

    // ── Drag & Drop ──────────────────────────────────────────────────
    uploadBox.addEventListener("dragover",  function (e) { e.preventDefault(); uploadBox.classList.add("drag-over"); });
    uploadBox.addEventListener("dragleave", function ()  { uploadBox.classList.remove("drag-over"); });
    uploadBox.addEventListener("drop",      function (e) {
      e.preventDefault();
      uploadBox.classList.remove("drag-over");
      var validation = validateFiles(Array.from(e.dataTransfer.files || []), selectedFiles);
      selectedFiles  = selectedFiles.concat(validation.files);
      updateFileInput();
      updateFilePreview();
      if (validation.errors.length) displayUploadError(validation.errors.join("<br>"));
    });

    // ── Init ─────────────────────────────────────────────────────────
    updateFilePreview();

  }, false);
</script>
