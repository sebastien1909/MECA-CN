<%- include ("header") %>

<main>
    <p>
        Bienvenue <strong><%= username %></strong>.<br>
        Vous souhaitez ajouter une offre d'emploi ?
    </p>

    <form action="/ajouteroffre" method="POST" class="ajout-form">

        <div class="row-two">
            <div class="intitule">
                <label>Intitulé de l'offre</label>
                <input class="intitule-input" id="intitule" name="intitule" type="text" placeholder="Assistant administratif..." />
            </div>
            <div class="type">
                <label>Type d'offre</label>
                <select name="type-offre" id="type">
                    <% for (const element of types){ %>
                        <option value="<%= element.type %>"><%= element.type %></option>
                    <% } %>
                </select>
            </div>
        </div>

        <div class="row-two">
            <div class="localisation">
                <label>Localisation</label>
                <input type="text" value="Widehem" id="localisation" name="localisation"/>
            </div>
            <div class="salaire">
                <label>Salaire proposé</label>
                <input type="text" placeholder="41 000 €/an" name="salaire" id="salaire"/>
            </div>
        </div>

        <div class="form-separator"></div>

        <div class="presentation">
            <label>Présentation de l'entreprise</label>
            <input type="text" value="<%= presentation %>" name="presentation" id="presentation"/>
        </div>

        <div class="missions">
            <label>Missions proposées</label>
            <input type="text" placeholder="Au sein de l'entreprise, vous devrez..." name="missions" id="missions"/>
        </div>

        <div class="methode">
            <label>Méthode de travail</label>
            <input type="text" placeholder="Télétravail" name="methode" id="methode"/>
        </div>

        <div class="competences">
            <label>Compétences recherchées</label>
            <input type="text" placeholder="Nous recherchons quelqu'un qui..." name="competences" id="competences"/>
        </div>

        <div class="avantage">
            <label>Avantages proposés</label>
            <input type="text" placeholder="À nos côtés, vous bénéficierez de..." name="avantage" id="avantage"/>
        </div>

        <div class="recrutement">
            <label>Processus de recrutement</label>
            <input type="text" placeholder="Si vous êtes sélectionnés..." name="recrutement" id="recrutement"/>
        </div>

        <div class="form-separator"></div>

        <div class="row-two">
            <div class="categorie">
                <label>Catégorie</label>
                <select name="categorie" id="categorie">
                    <% for (const element of categories){ %>
                        <option value="<%= element %>"><%= element %></option>
                    <% } %>
                    <option value="autre">Autre</option>
                </select>
            </div>
            <div class="autre-categorie" id="autre-categorie" style="display: none;">
                <label>Nouvelle catégorie</label>
                <input type="text" name="nouvelleCategorie" id="nouvelleCategorie" placeholder="Ex : Marketing"/>
            </div>
        </div>

        <div class="complementaire">
            <label>Informations complémentaires</label>
            <input type="text" placeholder="Informations supplémentaires..." name="complementaire" id="complementaire"/>
        </div>

        <div class="validate-holder">
            <button type="submit" class="validate-btn">Valider l'offre</button>
            <p>Pensez à bien vérifier les informations avant de valider</p>
        </div>

    </form>
</main>

<script>
    const categorieSelect = document.getElementById("categorie");
    const autreCategorie = document.getElementById("autre-categorie");

    categorieSelect.addEventListener("change", function(){
        autreCategorie.style.display = this.value === "autre" ? "block" : "none";
    });
</script>

<%- include("footer") %>