<%# Admin add new machine form (placeholder) %>


<%- include('./header') %>

<main>
    <section class="left-part">
        <h1>
            Ajouter une <span>machine</span>
        </h1>

        <div class="preview-wrapper preview-desktop">
            <div class="preview-container">
                <div class="preview-header">
                    <h4>Prévisualisation</h4>
                    <p class="preview-sub">Prévisualisez la carte de votre machine ici</p>
                </div>

                <div class="preview-frame">
                    <div class="preview-card">
                        <div class="preview-outer">
                            <div class="preview-left">
                                <div class="preview-top">
                                    <h3 id="preview-name"><%= (machine.nom_machine.length > 0 ? machine.nom_machine : 'Nom non spécifié') %></h3>
                                    <p id="preview-desc"><%= (machine.description_longue.length > 0 ? machine.description_longue : (machine.description_longue.length > 0 ? machine.description_courte : 'Description non spécifiée')) %></p>

                                    <div class="preview-info">
                                        <div class="preview-info-row" id="preview-stat1-row">
                                            <span class="label" id="preview-stat1-name"></span>
                                            <span class="value" id="preview-stat1-value"></span>
                                        </div>
                                        <div class="preview-info-row" id="preview-stat2-row" style="display:none;">
                                            <span class="label" id="preview-stat2-name"></span>
                                            <span class="value" id="preview-stat2-value"></span>
                                        </div>
                                        <div class="preview-info-row" id="preview-stat3-row" style="display:none;">
                                            <span class="label" id="preview-stat3-name"></span>
                                            <span class="value" id="preview-stat3-value"></span>
                                        </div>
                                        <div class="preview-info-row" id="preview-stat4-row" style="display:none;">
                                            <span class="label" id="preview-stat4-name"></span>
                                            <span class="value" id="preview-stat4-value"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="preview-bottom">
                                    <h4 id="preview-adv-title"><%= machine.avantage_titre %></h4>
                                    <p id="preview-adv-desc"><%= machine.avantage_description %></p>
                                </div>
                            </div>

                            <div class="preview-right">
                                <img id="preview-image-card" src="<%= machine.image_machine ? (machine.image_machine.match(/\.[a-z]{2,4}$/i) ? machine.image_machine : machine.image_machine + '.png') : '/img/icons/upload.png' %>" alt="Preview">
                                <div class="preview-main-info">
                                    <h4 id="preview-card-title"><%= machine.nom_machine %></h4>
                                    <span id="preview-year" class="date-holder"><%= machine.annee_entree %></span>
                                </div>
                                <p id="preview-shortdesc"><%= machine.description_courte %></p>

                                <div class="preview-dims">
                                    <!-- Fraisage -->
                                    <div id="preview-dims-fraisage" style="display:none;">
                                        <div class="dim"><strong>Dimension X</strong><span id="preview-dx"></span></div>
                                        <div class="dim"><strong>Dimension Y</strong><span id="preview-dy"></span></div>
                                        <div class="dim"><strong>Dimension Z</strong><span id="preview-dz"></span></div>
                                    </div>
                                    <!-- Tournage -->
                                    <div id="preview-dims-tournage" style="display:none;">
                                        <div class="dim"><strong>Longueur max</strong><span id="preview-longueur"></span></div>
                                        <div class="dim"><strong>Diamètre max</strong><span id="preview-diametre"></span></div>
                                        <div class="dim"><strong>Alèsage</strong><span id="preview-alesage"></span></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="preview-actions">
                    <button id="reload-preview" type="button" class="recharger-btn">Recharger</button>
                </div>
            </div>
        </div>
    </section>

    <section class="right-part">
        <form class="form-container" method="POST" enctype="multipart/form-data" action="/ajouter_machine">
            <div class="form-left">

                <div class="upload-box">
                    <div class="upload-icon">
                        <img id="preview-image" src="<%= machine.image_machine || '/img/icons/upload.png' %>" alt="Image machine">
                    </div>
                    <p id="upload-text">Image actuelle : <%= machine.image_machine || 'Aucune image' %></p>
                    <span id="upload-status"><%= machine.image_machine || '' %></span>
                    <button type="button" class="upload-button">Changer l'image</button>
                    <input type="file" name="image_machine" id="image_machine_input" style="display:none;">
                </div>

            </div>
            <div class="form-right">
                <div class="form-group" style="margin-bottom: 14px;">
                    <label>Nom de la machine</label>
                    <input type="text" name="nom_machine" value="<%= machine.nom_machine %>" required>
                </div>

                <div class="form-group" style="margin-bottom: 14px;">
                    <label>Description courte</label>
                    <input type="text" name="description_courte" value="<%= machine.description_courte %>">
                </div>

                <div class="form-group" style="margin-bottom: 14px;">
                    <label>Description longue</label>
                    <textarea name="description_longue" rows="4"><%= machine.description_longue %></textarea>
                </div>

                

                <div class="form-group">
                    <label>Type</label>
                    <select name="type" id="type-select">
                        <option value="fraisage" <%= machine.type === 'fraisage' ? 'selected' : '' %>>Fraisage</option>
                        <option value="tournage" <%= machine.type === 'tournage' ? 'selected' : '' %>>Tournage</option>
                        <option value="tournage/fraisage" <%= machine.type === 'tournage/fraisage' ? 'selected' : '' %>>Fraisage + Tournage </option>
                    </select>
                </div>
                        <!-- Dimensions fraisage -->
                        <div id="dims-fraisage">
                            <div class="form-group">
                                <label>Dimension X (mm)</label>
                                <input type="number" step="0.01" name="d_x" value="<%= machine.d_x %>">
                            </div>
                            <div class="form-group">
                                <label>Dimension Y (mm)</label>
                                <input type="number" step="0.01" name="d_y" value="<%= machine.d_y %>">
                            </div>
                            <div class="form-group">
                                <label>Dimension Z (mm)</label>
                                <input type="number" step="0.01" name="d_z" value="<%= machine.d_z %>">
                            </div>
                        </div>

                        <!-- Dimensions tournage -->
                        <div id="dims-tournage" style="display:none;">
                            <div class="form-group">
                                <label>Diamètre max (mm)</label>
                                <input type="number" step="0.01" name="diametre_max" value="<%= machine.diametre_max %>">
                            </div>
                            <div class="form-group">
                                <label>Longueur max (mm)</label>
                                <input type="number" step="0.01" name="longueur_max" value="<%= machine.longueur_max %>">
                            </div>
                            <div class="form-group">
                                <label>Alésage de broche (mm)</label>
                                <input type="number" step="0.01" name="alesage" value="<%= machine.alesage %>">
                            </div>
                        </div>






                    
                        <!-- ===== STATISTIQUES DYNAMIQUES ===== -->
                    <div id="stats-container">
                        <% for (let i = 1; i <= 4; i++) { %>
                            <div class="stat-group" id="stat-group-<%= i %>" style="<%= (!machine['statistique' + i + '_nom'] && i > 1) ? 'display:none;' : '' %>">
                                <div class="stat-group-header">
                                    <span class="stat-group-label">Statistique <%= i %></span>
                                    <% if (i > 1) { %>
                                        <button type="button" class="stat-remove-btn" data-index="<%= i %>">
                                            <i class="ti ti-trash" aria-hidden="true"></i> Retirer
                                        </button>
                                    <% } %>
                                </div>
                                <div class="form-group">
                                    <label>Nom</label>
                                    <input type="text" name="statistique<%= i %>_nom" 
                                        value="<%= machine['statistique' + i + '_nom'] || '' %>"
                                        placeholder="Ex: Puissance">
                                </div>
                                <div class="form-group">
                                    <label>Donnée</label>
                                    <input type="text" name="statistique<%= i %>_donnee" 
                                        value="<%= machine['statistique' + i + '_donnee'] || '' %>"
                                        placeholder="Ex: 12 000 tr/min">
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <button type="button" id="stat-add-btn" class="stat-add-btn">
                        <i class="ti ti-plus" aria-hidden="true"></i> Ajouter une statistique
                    </button>
                <!-- ===== FIN STATISTIQUES ===== -->



                     <div class="form-group">
                        <label>Avantage - Titre</label>
                        <input type="text" name="avantage_titre" value="<%= machine.avantage_titre %>">
                    </div>

                    <div class="form-group">
                        <label>Avantage - Description</label>
                        <textarea name="avantage_description" rows="3"><%= machine.avantage_description %></textarea>
                    </div>

                <div class="form-group">
                    <label>Année d'entrée</label>
                    <input type="number" name="annee_entree" value="<%= machine.annee_entree %>">
                </div>

                <a href="/admin/suppression" class="suppress_link">Supprimer une machine</a>
                <button type="submit" class="validate-btn">Valider</button>
            </div>
        </form>



        
        <!-- ========== PREVIEW MOBILE ========== -->
        <div class="preview-wrapper preview-mobile" id="preview-mobile-container-link">
            <div class="preview-container">
                <div class="preview-header">
                    <h4>Prévisualisation</h4>
                    <p class="preview-sub">Prévisualisez la carte de votre machine ici</p>
                </div>

                <div class="preview-frame">
                    <div class="preview-card preview-mobile-card">
                        <div class="mobile-image-wrapper" style="position:relative; width:100%;">
                            <img id="preview-mobile-image" src="<%= machine.image_machine ? (machine.image_machine.match(/\.[a-z]{2,4}$/i) ? machine.image_machine : machine.image_machine + '.png') : '/img/icons/upload.png' %>" alt="Preview mobile">
                            <div class="mobile-year-badge" id="preview-mobile-year"><%= machine.annee_entree %></div>
                        </div>

                        <h3 id="preview-mobile-name" class="mobile-title"><%= machine.nom_machine %></h3>

                        <p id="preview-mobile-desc" class="mobile-desc"><%= machine.description_courte || machine.description_longue || '' %></p>

                        <div class="mobile-stats">
                            <div class="mobile-stat" id="preview-mobile-stat1-row">
                                <div class="stat-label" id="preview-mobile-stat1-name"></div>
                                <div class="stat-value" id="preview-mobile-stat1-value"></div>
                            </div>
                            <div class="mobile-stat" id="preview-mobile-stat2-row" style="display:none;">
                                <div class="stat-label" id="preview-mobile-stat2-name"></div>
                                <div class="stat-value" id="preview-mobile-stat2-value"></div>
                            </div>
                            <div class="mobile-stat" id="preview-mobile-stat3-row" style="display:none;">
                                <div class="stat-label" id="preview-mobile-stat3-name"></div>
                                <div class="stat-value" id="preview-mobile-stat3-value"></div>
                            </div>
                            <div class="mobile-stat" id="preview-mobile-stat4-row" style="display:none;">
                                <div class="stat-label" id="preview-mobile-stat4-name"></div>
                                <div class="stat-value" id="preview-mobile-stat4-value"></div>
                            </div>
                        </div>


                        <!-- Dimensions mobile — fraisage -->
                        <div id="preview-mobile-dims-fraisage" style="display:none;">
                            <p style="margin-top:20px;"><strong>Dimensions de Fraisage</strong></p>
                            <div class="info1">
                                <p>Dimension X</p>
                                <p id="preview-mobile-dx"></p>
                            </div>
                            <div class="info2">
                                <p>Dimension Y</p>
                                <p id="preview-mobile-dy"></p>
                            </div>
                            <div class="info3">
                                <p>Dimension Z</p>
                                <p id="preview-mobile-dz"></p>
                            </div>
                        </div>

                        <!-- Dimensions mobile — tournage -->
                        <div id="preview-mobile-dims-tournage" style="display:none;">
                            <p style="margin-top:20px;"><strong>Dimensions de Tournage</strong></p>
                            <div class="info1">
                                <p>Longueur max</p>
                                <p id="preview-mobile-longueur"></p>
                            </div>
                            <div class="info2">
                                <p>Diamètre max</p>
                                <p id="preview-mobile-diametre"></p>
                            </div>
                            <div class="info3">
                                <p>Alésage</p>
                                <p id="preview-mobile-alesage"></p>
                            </div>
                        </div>


                        
                    </div>
                </div>

                <div class="preview-actions">
                    <button id="reload-preview-mobile" type="button" class="recharger-btn">Recharger</button>
                </div>
            </div>
        </div>
    </section>

</main>


<!-- Bouton de navigation rapide Preview / Formulaire sur Mobile -->
<button type="button" id="mobile-nav-toggle" class="mobile-nav-btn" data-target="down">
    <span class="nav-btn-icon">↓</span>
    <span class="nav-btn-text">Voir la prévisualisation</span>
</button>


<script>
    (function(){
        const uploadButton = document.querySelector('.upload-button');
        const fileInput = document.getElementById('image_machine_input');
        const uploadStatus = document.getElementById('upload-status');
        const uploadText = document.getElementById('upload-text');
        const previewImage = document.getElementById('preview-image');
        const previewCardImage = document.getElementById('preview-image-card');
        const previewMobileImage = document.getElementById('preview-mobile-image');
        const typeSelect = document.getElementById('type-select');
        const dimsFraisage = document.getElementById('dims-fraisage');
        const dimsTournage = document.getElementById('dims-tournage');
        const previewDimsFraisage = document.getElementById('preview-dims-fraisage');
        const previewDimsTournage = document.getElementById('preview-dims-tournage');
        const previewMobileDimsFraisage = document.getElementById('preview-mobile-dims-fraisage');
        const previewMobileDimsTournage = document.getElementById('preview-mobile-dims-tournage');

        // --- Gestion dynamique des statistiques ---
        const statAddBtn = document.getElementById('stat-add-btn');

        function getVisibleStatCount() {
            let count = 0;
            for (let i = 1; i <= 4; i++) {
                const group = document.getElementById('stat-group-' + i);
                if (group && group.style.display !== 'none') count++;
            }
            return count;
        }

        function refreshStatButtons() {
            if (statAddBtn) statAddBtn.disabled = getVisibleStatCount() >= 4;
        }

        if (statAddBtn) {
            statAddBtn.addEventListener('click', () => {
                for (let i = 1; i <= 4; i++) {
                    const group = document.getElementById('stat-group-' + i);
                    if (group && group.style.display === 'none') {
                        group.style.display = '';
                        refreshStatButtons();
                        updatePreview();
                        break;
                    }
                }
            });
        }

        document.querySelectorAll('.stat-remove-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const idx = btn.getAttribute('data-index');
                const group = document.getElementById('stat-group-' + idx);
                if (!group) return;
                group.querySelectorAll('input').forEach(input => input.value = '');
                group.style.display = 'none';
                refreshStatButtons();
                updatePreview();
            });
        });

        refreshStatButtons();
        // --- Fin gestion stats ---

        function updateDimsVisibility() {
            const val = typeSelect.value;
            dimsFraisage.style.display = (val === 'fraisage' || val === 'tournage/fraisage') ? '' : 'none';
            dimsTournage.style.display = (val === 'tournage' || val === 'tournage/fraisage') ? '' : 'none';
        }

        function updatePreviewDimsVisibility(type) {
            if (previewDimsFraisage) previewDimsFraisage.style.display = (type === 'fraisage' || type === 'tournage/fraisage') ? '' : 'none';
            if (previewDimsTournage) previewDimsTournage.style.display = (type === 'tournage' || type === 'tournage/fraisage') ? '' : 'none';
            if (previewMobileDimsFraisage) previewMobileDimsFraisage.style.display = (type === 'fraisage' || type === 'tournage/fraisage') ? '' : 'none';
            if (previewMobileDimsTournage) previewMobileDimsTournage.style.display = (type === 'tournage' || type === 'tournage/fraisage') ? '' : 'none';
        }

        if (typeSelect) {
            typeSelect.addEventListener('change', () => {
                updateDimsVisibility();
                updatePreview();
            });
            updateDimsVisibility();
        }

        if (uploadButton) uploadButton.addEventListener('click', () => fileInput && fileInput.click());

        if (fileInput) {
            fileInput.addEventListener('change', () => {
                const file = fileInput.files[0];
                if (!file) return;
                if (uploadText) uploadText.innerText = 'Nouvelle image sélectionnée';
                if (uploadStatus) {
                    uploadStatus.innerText = file.name;
                    uploadStatus.style.color = '#0f4bb7';
                    uploadStatus.style.fontWeight = 'bold';
                }
                const url = URL.createObjectURL(file);
                if (previewImage) previewImage.src = url;
                if (previewCardImage) previewCardImage.src = url;
                if (previewMobileImage) previewMobileImage.src = url;
            });
        }

        function setIf(id, value) {
            const el = document.getElementById(id);
            if (el) el.textContent = value;
        }

        function updatePreview() {
            const get = s => document.querySelector(s);

            const name      = (get('[name="nom_machine"]')         || {}).value || 'Nom machine';
            const descLong  = (get('[name="description_longue"]')  || {}).value || '';
            const descShort = (get('[name="description_courte"]')  || {}).value || '';
            const advTitle  = (get('[name="avantage_titre"]')      || {}).value || '';
            const advDesc   = (get('[name="avantage_description"]')|| {}).value || '';
            const year      = (get('[name="annee_entree"]')        || {}).value || '';
            const type      = typeSelect ? typeSelect.value : '';

            const dx       = (get('[name="d_x"]')         || {}).value || '';
            const dy       = (get('[name="d_y"]')         || {}).value || '';
            const dz       = (get('[name="d_z"]')         || {}).value || '';
            const longueur = (get('[name="longueur_max"]') || {}).value || '';
            const diametre = (get('[name="diametre_max"]') || {}).value || '';
            const alesage  = (get('[name="alesage"]')      || {}).value || '';

            // Desktop — textes généraux
            setIf('preview-name',       name);
            setIf('preview-card-title', name);
            setIf('preview-desc',       descLong || descShort);
            setIf('preview-shortdesc',  descShort);
            setIf('preview-adv-title',  advTitle);
            setIf('preview-adv-desc',   advDesc);
            setIf('preview-year',       year);

            // Desktop — dimensions
            setIf('preview-dx',       dx       ? dx       + ' mm' : '');
            setIf('preview-dy',       dy       ? dy       + ' mm' : '');
            setIf('preview-dz',       dz       ? dz       + ' mm' : '');
            setIf('preview-longueur', longueur ? longueur + ' mm' : '');
            setIf('preview-diametre', diametre ? diametre + ' mm' : '');
            setIf('preview-alesage',  alesage  ? alesage  + ' mm' : '');

            updatePreviewDimsVisibility(type);

            // Mobile — textes généraux
            setIf('preview-mobile-name', name);
            setIf('preview-mobile-desc', descShort || descLong);
            setIf('preview-mobile-year', year);

            // Mobile — dimensions
            setIf('preview-mobile-dx',       dx       ? dx       + ' mm' : '');
            setIf('preview-mobile-dy',       dy       ? dy       + ' mm' : '');
            setIf('preview-mobile-dz',       dz       ? dz       + ' mm' : '');
            setIf('preview-mobile-longueur', longueur ? longueur + ' mm' : '');
            setIf('preview-mobile-diametre', diametre ? diametre + ' mm' : '');
            setIf('preview-mobile-alesage',  alesage  ? alesage  + ' mm' : '');

            // --- Statistiques desktop + mobile ---
            // On vide et masque tous les slots
            for (let i = 1; i <= 4; i++) {
                setIf('preview-stat' + i + '-name',  '');
                setIf('preview-stat' + i + '-value', '');
                setIf('preview-mobile-stat' + i + '-name',  '');
                setIf('preview-mobile-stat' + i + '-value', '');
                const desktopRow = document.getElementById('preview-stat' + i + '-row');
                const mobileRow  = document.getElementById('preview-mobile-stat' + i + '-row');
                if (desktopRow) desktopRow.style.display = 'none';
                if (mobileRow)  mobileRow.style.display  = 'none';
            }

            // On remplit et affiche uniquement les slots visibles et renseignés
            let previewStatIdx = 1;
            for (let i = 1; i <= 4; i++) {
                const group = document.getElementById('stat-group-' + i);
                if (!group || group.style.display === 'none') continue;
                const nom = (get('[name="statistique' + i + '_nom"]')    || {}).value || '';
                const val = (get('[name="statistique' + i + '_donnee"]') || {}).value || '';
                if (nom || val) {
                    setIf('preview-stat' + previewStatIdx + '-name',  nom);
                    setIf('preview-stat' + previewStatIdx + '-value', val);
                    setIf('preview-mobile-stat' + previewStatIdx + '-name',  nom);
                    setIf('preview-mobile-stat' + previewStatIdx + '-value', val);
                    const desktopRow = document.getElementById('preview-stat' + previewStatIdx + '-row');
                    const mobileRow  = document.getElementById('preview-mobile-stat' + previewStatIdx + '-row');
                    if (desktopRow) desktopRow.style.display = '';
                    if (mobileRow)  mobileRow.style.display  = '';
                    previewStatIdx++;
                }
            }
            // --- Fin statistiques ---

            const file = fileInput && fileInput.files && fileInput.files[0];
            if (file) {
                const url = URL.createObjectURL(file);
                if (previewCardImage)   previewCardImage.src   = url;
                if (previewMobileImage) previewMobileImage.src = url;
            }
        }

        const desktopReload = document.getElementById('reload-preview');
        if (desktopReload) desktopReload.addEventListener('click', updatePreview);
        const mobileReload = document.getElementById('reload-preview-mobile');
        if (mobileReload) mobileReload.addEventListener('click', updatePreview);

        updatePreview();
    })();





    // --- Gestion du bouton de navigation rapide Mobile ---
    const mobileNavBtn = document.getElementById('mobile-nav-toggle');
    const mobilePreviewZone = document.getElementById('preview-mobile-container-link');

    if (mobileNavBtn && mobilePreviewZone) {
        mobileNavBtn.addEventListener('click', () => {
            const target = mobileNavBtn.getAttribute('data-target');
            if (target === 'down') {
                mobilePreviewZone.scrollIntoView({ behavior: 'smooth' });
            } else {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        });

        window.addEventListener('scroll', () => {
            const rect = mobilePreviewZone.getBoundingClientRect();
            if (rect.top <= window.innerHeight * 0.7) {
                mobileNavBtn.setAttribute('data-target', 'up');
                mobileNavBtn.querySelector('.nav-btn-icon').textContent = '↑';
                mobileNavBtn.querySelector('.nav-btn-text').textContent = 'Retour au formulaire';
            } else {
                mobileNavBtn.setAttribute('data-target', 'down');
                mobileNavBtn.querySelector('.nav-btn-icon').textContent = '↓';
                mobileNavBtn.querySelector('.nav-btn-text').textContent = 'Voir la prévisualisation';
            }
        });
    }
</script>

<%- include('./footer') %>