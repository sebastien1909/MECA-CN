<%- include('./header') %>

<main>
    <div class="content-wrapper">
        <section class="left-part">
            <h1>Vous souhaitez ajouter une <span>Catégorie ?</span></h1>
        </section>

        <section class="right-part">
            <div class="form-card">
                <h2>Ajoutez une catégorie</h2>
                <p class="subtitle">Veuillez renseigner toutes les informations demandées</p>

                <form class="form-single-col" method="POST" action="/ajouter_categorie">
                    <div class="form-group">
                        <label>Nom de la catégorie</label>
                        <input type="text" name="nom_categorie" placeholder="Ex: Pièce aéronautique" value="<%= (typeof categorie !== 'undefined' && categorie && categorie.nom) ? categorie.nom : '' %>" required>
                    </div>

                    <% if (typeof produits !== 'undefined' && produits && produits.length > 0) { %>
                    <div class="form-group">
                        <label>Associer un produit (optionnel)</label>
                        <select name="produit_associe">
                            <option value="">— Aucun —</option>
                            <% produits.forEach(p => { %>
                                <option value="<%= p.id %>"><%= p.nom %></option>
                            <% }) %>
                        </select>
                        <p class="note">Sélectionnez un produit sans catégorie pour l'affecter à cette nouvelle catégorie.</p>
                    </div>
                    <% } %>

                    <div class="form-actions">
                        <button type="submit" class="btn-validate">Valider</button>
                    </div>
                </form>

                <div class="footer-form">
                    <a href="/admin/suppression" class="link-delete">Supprimer une catégorie</a>
                </div>
            </div>
        </section>
    </div>
</main>

<%- include('./footer') %>