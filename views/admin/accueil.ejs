<script>
    document.addEventListener('DOMContentLoaded', function() {
        const navLinks = Array.from(document.querySelectorAll('.link-container a[href^="#"]'));
        const sections = navLinks
            .map(link => document.querySelector(link.getAttribute('href')))
            .filter(Boolean);

        if (!sections.length) return;

        const setActiveLink = (hash) => {
            navLinks.forEach(link => {
                link.classList.toggle('active', link.getAttribute('href') === hash);
            });
        };

        const navbar = document.querySelector('.navbar');

        const updateActiveLink = () => {
            const offset = (navbar ? navbar.offsetHeight : 0) + window.innerHeight * 0.15;
            const scrollPosition = window.pageYOffset + offset;
            const firstSectionTop = sections[0].offsetTop;

            if (window.pageYOffset < firstSectionTop - window.innerHeight * 0.3) {
                setActiveLink('');
                return;
            }

            let activeId = sections[0].id;
            for (const section of sections) {
                if (scrollPosition >= section.offsetTop) {
                    activeId = section.id;
                } else {
                    break;
                }
            }

            setActiveLink(`#${activeId}`);
        };

        updateActiveLink();
        window.addEventListener('scroll', updateActiveLink);
        window.addEventListener('resize', updateActiveLink);
        window.addEventListener('hashchange', () => {
            setActiveLink(window.location.hash);
        });
    });
</script>

