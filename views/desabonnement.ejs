<%- include("header") %>

<main style="min-height: 60vh; display: flex; align-items: center; justify-content: center; padding: 40px 20px;">
  <div style="max-width: 480px; width: 100%; background: #fff; border-radius: 18px; padding: 40px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); text-align: center;">

    <% if (locals.success) { %>
      <!-- État : désabonné avec succès -->
      <div style="font-size: 48px; margin-bottom: 16px;">✓</div>
      <h1 style="font-size: 1.4rem; color: #1f2937; margin: 0 0 12px;">Désabonnement confirmé</h1>
      <p style="color: #64748b; margin: 0 0 28px;">
        L'adresse <strong><%= email %></strong> ne recevra plus nos newsletters.
      </p>
      <a href="/" style="display: inline-block; background: #0f4bb7; color: #fff; text-decoration: none; padding: 12px 28px; border-radius: 8px; font-weight: 700;">
        Retour à l'accueil
      </a>

    <% } else { %>
      <!-- État : formulaire de désabonnement -->
      <h1 style="font-size: 1.4rem; color: #1f2937; margin: 0 0 8px;">Se désabonner</h1>
      <p style="color: #64748b; margin: 0 0 24px;">
        Confirmez votre adresse mail pour vous désabonner de la newsletter MECA-CN.
      </p>

      <% if (locals.error) { %>
        <p style="color: #e53e3e; background: #fff5f5; border-radius: 8px; padding: 10px 16px; margin-bottom: 16px; font-size: 0.9rem;">
          <%= error %>
        </p>
      <% } %>

      <form method="POST" action="/desabonnement">
        <input
          type="email"
          name="email"
          value="<%= email %>"
          placeholder="votre@email.com"
          required
          style="width: 100%; padding: 12px 16px; border: 1.5px solid #e2e8f0; border-radius: 8px; font-size: 1rem; box-sizing: border-box; margin-bottom: 16px;"
        />
        <button
          type="submit"
          style="width: 100%; background: #e53e3e; color: #fff; border: none; padding: 13px; border-radius: 8px; font-size: 1rem; font-weight: 700; cursor: pointer;"
        >
          Me désabonner
        </button>
      </form>

      <a href="/" style="display: inline-block; margin-top: 16px; color: #94a3b8; font-size: 0.9rem; text-decoration: none;">
        Annuler, retour à l'accueil
      </a>
    <% } %>

  </div>
</main>

<%- include("footer") %>