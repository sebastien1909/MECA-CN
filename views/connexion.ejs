<%- include('header') %>

<main class="connexion-page">
    <section class="connexion-hero">
        <div class="hero-content">
            <span class="hero-eyebrow">Vous êtes</span>
            <h1>Administrateur ?</h1>
            <p class="hero-text">Accédez au Back Office administratif de MECA-CN. Gestion des contenus, informations sur le trafic du site et modification des données, tout est disponible dans votre espace sécurisé.</p>
            <div class="status-card">
                <span class="status-dot"></span>
                <div>
                    <p>Status</p>
                    <strong>Opérationnel</strong>
                </div>
            </div>
        </div>
    </section>

    <section class="connexion-card">
        <div class="card-head">
            <p>Connectez-vous pour accéder à votre</p>
            <h2>BackOffice</h2>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="connexion-error"><%= error %></div>
        <% } %>

        <form action="/connexion" method="post" class="connexion-form">
            <div class="connexion-group">
                <label for="id_user">Identifiant *</label>
                <input type="text" id="id_user" name="id_user" placeholder="Votre identifiant" required>
            </div>
            <div class="connexion-group">
                <label for="password">Mot de passe *</label>
                <input type="password" id="password" name="password" placeholder="********" required>
            </div>
            <div class="forgot-line">
                <a href="#">Mot de passe oublié ?</a>
            </div>
            <button type="submit" class="connexion-submit">Se connecter</button>
        </form>
    </section>
</main>

<%- include('footer') %>


