<%# Public machines listing (parc machine) %>
<%- include('header') %>


    <section class="top-title">
        <div class="top-left">
            <h3>GRANDE CAPACITÉ DE PRODUCTION</h3>
            <h2>Parc Machine <br> <span>Haute Précision</span></h2>
        </div>

        <div class="top-right">
            <p>
                Notre atelier intègre les dernières technologies de tournage et fraisage pour répondre aux tolérances les plus exigeantes des secteurs automobile et médical.
            </p>
        </div>
    </section>




  <section class="machine-container pc-only">

    <div class="filter-wrapper">
        <button class="filter-btn active" data-filter="all">Tous</button>
        <button class="filter-btn" data-filter="fraisage">Fraisage</button>
        <button class="filter-btn" data-filter="tournage">Tournage</button>
    </div>




   



    <!-- ================= GROUP TOURNAGE ================= -->
    <div class="filter-group tournage-group ">
        <div class="title-holder">
            <h4 class="section-title tournage-title">Tournage</h4>
            <div class="separateur"></div>
        </div>
        <% for (const element of machinestourneuses) { %>
            <section class="machine-holder reveal-machine">

                <div class="first-column">
                    <div class="top-part">
                        <h2><%= element.nom_machine %></h2>
                        <p><%= element.description_longue %></p>

                        <% 
                        let indexTournage = 1;
                        for (let cle in element) { 
                            if (cle.includes("_nom")) { 
                                const nomStat = element[cle];
                                const valeurStat = element[cle.replace("_nom", "_donnee")];

                                if (nomStat && nomStat.trim() !== '' && valeurStat && valeurStat.trim() !== '') { 
                        %>
                                    <div class="info<%= indexTournage %>">
                                        <p><%= nomStat %></p>
                                        <p><%= valeurStat %></p>
                                    </div>
                        <% 
                                    indexTournage++;
                                } 
                            } 
                        } 
                        %>
                    </div>

                    <div class="bottom-part">
                        <h2><%= element.avantage_titre %></h2>
                        <p><%= element.avantage_description %></p>
                    </div>
                </div>

                <div class="second-column">
                    <img src="<%= element.image_machine %>" alt="Machine <%= element.nom_machine %>">
                    <div class="main-info-top">
                        <h4><%= element.nom_machine %></h4>
                        <span class="date-holder"><%= element.annee_entree %></span>
                    </div>
                    
                    <p><%= element.description_courte %></p>

                    <div class="stats-holder">
                        <div class="first-stat">
                            <h5>Diamètre max</h5>
                            <span><%= element.diametre_max %></span>
                        </div>
                        <div class="second-stat">
                            <h5>longueur max</h5>
                            <span><%= element.longueur_max %></span>
                        </div>
                        <div class="third-stat">
                            <h5>alesage</h5>
                            <span><%= element.alesage %></span>
                        </div>
                    </div>
                </div>

            </section>
        <% } %>
    </div>

    <!-- ================= GROUP FRAISAGE ================= -->
    <div class="filter-group fraisage-group">
        <div class="title-holder">
            <h4 class="section-title fraisage-title">Fraisage</h4>
            <div class="separateur"></div>
        </div>
        <% if (typeof machinefraiser == 'undefined' || machinefraiser.length === 0) { %>
            <p class="no-data">Aucune machine de fraisage enregistrée.</p>
        <% } %>

        <% for (const element of machinefraiser) { %>
            <section class="machine-holder reveal-machine">
                
                <div class="first-column">
                    <div class="top-part">
                        <h2><%= element.nom_machine %></h2>
                        <p><%= element.description_longue %></p>

                        <% 
                        let indexFraisage = 1;
                        for (let cle in element) { 
                            if (cle.includes("_nom")) { 
                                const nomStat = element[cle];
                                const valeurStat = element[cle.replace("_nom", "_donnee")];

                                if (nomStat && nomStat.trim() !== '' && valeurStat && valeurStat.trim() !== '') { 
                        %>
                                    <div class="info<%= indexFraisage %>">
                                        <p><%= nomStat %></p>
                                        <p><%= valeurStat %></p>
                                    </div>
                        <% 
                                    indexFraisage++;
                                } 
                            } 
                        } 
                        %>
                    </div>

                    <div class="bottom-part">
                        <h2><%= element.avantage_titre %></h2>
                        <p><%= element.avantage_description %></p>
                    </div>
                </div>

                <div class="second-column">
                    <img src="<%= element.image_machine %>" alt="Machine <%= element.nom_machine %>">
                    <div class="main-info-top">
                        <h4><%= element.nom_machine %></h4>
                        <span class="date-holder"><%= element.annee_entree %></span>
                    </div>
                    
                    <p><%= element.description_courte %></p>

                    <div class="stats-holder">
                        <div class="first-stat">
                            <h5>dimension X</h5>
                            <span><%= element.d_x %></span>
                        </div>
                        <div class="second-stat">
                            <h5>dimension Y</h5>
                            <span><%= element.d_y %></span>
                        </div>
                        <div class="third-stat">
                            <h5>dimension Z</h5>
                            <span><%= element.d_z %></span>
                        </div>
                    </div>
                </div>

            </section>
        <% } %>
    </div>




     <!-- ========== GROUPE TOURNAGE ET FRAISAGE ========== -->

        <div class="filter-group tournage-group ">
            <div class="title-holder">
                <h4 class="section-title tournage-title">Machines de tournage et fraisage</h4>
                <div class="separateur" style="width:50%;"></div>
            </div>
            
            <% if (typeof machineglobale == 'undefined' || machineglobale.length === 0) { %>
                <p class="no-data">Aucune machine de tournage enregistrée.</p>
            <% } %>
            <% for (const element of machineglobale) { %>
                <section class="machine-holder">

                    <a href="/modif_machine/<%= element.id_machine %>">
                        <img src="/img/icons/modifier.svg" alt="Modifier la réalisation">
                    </a>


                    <div class="first-column">
                        <div class="top-part">
                            <h2><%= element.nom_machine %></h2>
                            <p><%= element.description_longue %></p>
                            <% 
                            // On boucle sur toutes les propriétés de la machine en cours
                            for (let cle in element) { 
                                // On cherche uniquement les clés qui contiennent "_nom" (ex: statistique1_nom)
                                if (cle.includes("_nom")) { 
                                    const nomStat = element[cle];
                                    // On récupère la donnée associée en remplaçant "_nom" par "_donnee"
                                    const cleDonnee = cle.replace("_nom", "_donnee");
                                    const valeurStat = element[cleDonnee];

                                    // On n'affiche le bloc que si le nom ET la donnée existent et ne sont pas vides
                                    if (nomStat && nomStat.trim() !== '' && valeurStat && valeurStat.trim() !== '') { 
                            %>
                                        <div class="info1">
                                            <p><%= nomStat %></p>
                                            <p><%= valeurStat %></p>
                                        </div>
                            <% 
                                    } 
                                } 
                            } 
                            %>
                        </div>

                        <div class="bottom-part">
                            <h2>
                                <%= element.avantage_titre %>
                            </h2>

                            <p>
                                <%= element.avantage_description %>
                            </p>
                        </div>
                    </div>






                    <div class="second-column">
                        <img src="<%= element.image_machine %>" alt="Machine Mazak">
                        <div class="main-info-top">
                            <h4><%= element.nom_machine %></h4>
                            <span class="date-holder">
                                <%= element.annee_entree %>
                            </span>
                        </div>
                        
                        <p> 
                            <%= element.description_courte %>
                        </p>

                        <div class="stats-holder" style="margin-bottom:15px;">
                            <div class="first-stat">
                                <h5>Longueur max</h5>
                                <span><%= element.longueur_max %>mm</span>
                            </div>

                            <div class="second-stat">
                                <h5>Diamètre max</h5>
                                <span><%= element.diametre_max %>mm</span>
                            </div>

                            <div class="third-stat">
                                <h5>Alèsage</h5>
                                <span><%= element.alesage %>mm</span>
                            </div>
                        </div>
                        <div class="stats-holder">
                            <div class="first-stat">
                                <h5>Dimension X</h5>
                                <span><%= element.d_x %>mm</span>
                            </div>

                            <div class="second-stat">
                                <h5>Dimension Y</h5>
                                <span><%= element.d_y %>mm</span>
                            </div>

                            <div class="third-stat">
                                <h5>Dimension Z</h5>
                                <span><%= element.d_z %>mm</span>
                            </div>
                        </div>

                    </div>

        
                </section>

            <% } %>
        </div>
</section>













    <section class="machine-container pc-hidden">
        <div class="filter-wrapper">
            <button class="filter-btn active" data-filter="all">Tous</button>
            <button class="filter-btn" data-filter="fraisage">Fraisage</button>
            <button class="filter-btn" data-filter="tournage">Tournage</button>
        </div>

        <% for (const machine of machines) { %>
            <section class="machine-holder-mobile" data-type="<%= machine.type %>">
                
                <div class="machine-card-image">
                    <span class="badge-entree"><%= machine.annee_entree %></span>
                    <img src="<%= machine.image_machine %>" alt="Machine <%= machine.nom_machine %>">
                </div>

                <div class="machine-card-content">
                    <div class="machine-card-header">
                        <h2 class="machine-subtitle"><%= machine.nom_machine %></h2>
                    </div>

                    <div class="machine-card-stats">
                        <% 
                        // On boucle sur toutes les propriétés de la machine en cours
                        for (let cle in machine) { 
                            // On cherche uniquement les clés qui contiennent "_nom" (ex: statistique1_nom)
                            if (cle.includes("_nom")) { 
                                const nomStat = machine[cle];
                                // On récupère la donnée associée en remplaçant "_nom" par "_donnee"
                                const cleDonnee = cle.replace("_nom", "_donnee");
                                const valeurStat = machine[cleDonnee];

                                // On n'affiche le bloc que si le nom ET la donnée existent et ne sont pas vides
                                if (nomStat && nomStat.trim() !== '' && valeurStat && valeurStat.trim() !== '') { 
                        %>
                                    <div class="mobile-stat-box">
                                        <span class="stat-label"><%= nomStat %></span>
                                        <span class="stat-value"><%= valeurStat %></span>
                                    </div>
                        <% 
                                } 
                            } 
                        } 
                        %>
                    </div>



                    <% if (machine.type === 'fraisage') { %>
                        <div class="info1">
                            <p>Dimension X</p>
                            <p><%= machine.d_x %></p>
                        </div>
                        <div class="info2">
                            <p>Dimension Y</p>
                            <p><%= machine.d_y %></p>
                        </div>
                        <div class="info3">
                            <p>Dimension Z</p>
                            <p><%= machine.d_z %></p>
                        </div>
                    <% } else if (machine.type === 'tournage') { %>
                        <div class="info1">
                            <p>Longueur max</p>
                            <p><%= machine.longueur_max %></p>
                        </div>
                        <div class="info2">
                            <p>Diamètre max</p>
                            <p><%= machine.diametre_max %></p>
                        </div>
                        <div class="info3">
                            <p>Alésage</p>
                            <p><%= machine.alesage %></p>
                        </div>
                    <% } %>

                    <p class="machine-card-desc">
                        <%= machine.description_courte %>
                    </p>
                </div>
            </section>
        <% } %>
    </section>



<script>
    document.querySelectorAll('.filter-btn').forEach(button => {
        button.addEventListener('click', () => {
            const filter = button.getAttribute('data-filter');

            // 1. Gérer l'état actif des boutons (desktop + mobile)
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');

            // 2. Filtrer les sections Desktop
            const tournageGroup = document.querySelector('.tournage-group');
            const fraisageGroup = document.querySelector('.fraisage-group');

            if (filter === 'all') {
                tournageGroup?.classList.remove('hidden');
                fraisageGroup?.classList.remove('hidden');
            } else if (filter === 'tournage') {
                tournageGroup?.classList.remove('hidden');
                fraisageGroup?.classList.add('hidden');
            } else if (filter === 'fraisage') {
                tournageGroup?.classList.add('hidden');
                fraisageGroup?.classList.remove('hidden');
            }

            // 3. Filtrer la version mobile (chaque carte a maintenant data-type)
            const mobileCards = document.querySelectorAll('.machine-holder-mobile');
            if (filter === 'all') {
                mobileCards.forEach(card => card.classList.remove('hidden'));
            } else {
                mobileCards.forEach(card => {
                    if (card.dataset.type === filter) card.classList.remove('hidden');
                    else card.classList.add('hidden');
                });
            }
        });
    });
</script>



<%- include('footer') %>